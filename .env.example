# ─────────────────────────────────────────────────────────────
# SIS Questionnaire Platform — environment variables
# Copy to .env.local. ALL backend integrations are OPTIONAL.
# With none set, the app runs on a local file-based data store.
# ─────────────────────────────────────────────────────────────

# --- Admin dashboard access -----------------------------------
# Token required to view /admin (sent as ?key= or x-admin-token header / cookie).
ADMIN_TOKEN=change-me-in-production

# --- Supabase (optional) --------------------------------------
# When both are set, responses persist to Supabase Postgres
# instead of the local file store. Run db/supabase-schema.sql first.
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Google Sheets sync (optional) ----------------------------
# When set, each submission is mirrored into the spreadsheet
# (one tab per questionnaire: PRE_TEENS_13_17, etc.).
GOOGLE_SHEETS_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Use \n for newlines in the private key, wrapped in quotes.
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# --- AI image generation (optional) ---------------------------
# When set, /api/images can generate competency illustrations
# from the prompt registry. Otherwise placeholders are shown.
IMAGE_API_PROVIDER=
IMAGE_API_KEY=

# --- WordPress embedding --------------------------------------
# Origin of the WordPress site allowed to iframe /embed/* routes.
WORDPRESS_EMBED_ORIGIN=https://your-wordpress-site.example

# Public base URL of this app (used in report links + embeds).
NEXT_PUBLIC_APP_URL=http://localhost:3000
